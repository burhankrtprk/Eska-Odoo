<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="product_product_delivery_aras" model="product.product">
            <field name="name">Aras Kargo Teslimat Bedeli</field>
            <field name="type">service</field>
            <field name="categ_id" ref="delivery.product_category_deliveries"/>
            <field name="sale_ok" eval="False"/>
            <field name="purchase_ok" eval="False"/>
            <field name="list_price">0.0</field>
        </record>

        <record id="aras_packaging_envelope" model="stock.package.type">
            <field name="name">Aras Zarf / Belge</field>
            <field name="shipper_package_code">1</field>
            <field name="package_carrier_type">aras</field>
        </record>

        <record id="aras_packaging_box" model="stock.package.type">
            <field name="name">Aras Standart Kutu</field>
            <field name="shipper_package_code">2</field>
            <field name="package_carrier_type">aras</field>
        </record>

        <record id="delivery_carrier_aras" model="delivery.carrier">
            <field name="name">Aras Kargo</field>
            <field name="product_id" ref="aras_delivery_integration.product_product_delivery_aras"/>
            <field name="delivery_type">aras</field>
            <field name="country_ids" eval="[(6, 0, [ref('base.tr')])]"/>
        </record>

    </data>
</odoo>
